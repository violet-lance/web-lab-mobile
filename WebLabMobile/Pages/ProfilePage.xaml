<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebLabMobile.Pages.ProfilePage"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="Profile"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Accent}"
                   Margin="0,16,0,8" />

            <Border BackgroundColor="{StaticResource CardBackground}"
                    Stroke="{StaticResource BorderColor}"
                    StrokeShape="RoundRectangle 10"
                    Padding="20">
                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Name" TextColor="{StaticResource TextSecondary}" FontSize="13" WidthRequest="80" />
                        <Label x:Name="NameLabel" Grid.Column="1" TextColor="White" FontSize="14" FontAttributes="Bold" />
                    </Grid>

                    <BoxView Color="{StaticResource BorderColor}" HeightRequest="1" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Email" TextColor="{StaticResource TextSecondary}" FontSize="13" WidthRequest="80" />
                        <Label x:Name="EmailLabel" Grid.Column="1" TextColor="White" FontSize="14" />
                    </Grid>

                    <BoxView Color="{StaticResource BorderColor}" HeightRequest="1" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Gender" TextColor="{StaticResource TextSecondary}" FontSize="13" WidthRequest="80" />
                        <Label x:Name="GenderLabel" Grid.Column="1" TextColor="White" FontSize="14" />
                    </Grid>

                    <BoxView Color="{StaticResource BorderColor}" HeightRequest="1" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Birthday" TextColor="{StaticResource TextSecondary}" FontSize="13" WidthRequest="80" />
                        <Label x:Name="DobLabel" Grid.Column="1" TextColor="White" FontSize="14" />
                    </Grid>

                    <BoxView Color="{StaticResource BorderColor}" HeightRequest="1" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="Member" TextColor="{StaticResource TextSecondary}" FontSize="13" WidthRequest="80" />
                        <Label x:Name="MemberSinceLabel" Grid.Column="1" TextColor="White" FontSize="14" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Button Text="Log Out"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Accent}"
                    BorderColor="{StaticResource Accent}"
                    BorderWidth="1"
                    CornerRadius="8"
                    Clicked="OnLogoutClicked"
                    Margin="0,8,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
